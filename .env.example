# 网站运营-web-ops · 环境变量模板
# ----------------------------------------------------------------------
# 用法：
#   1. cp .env.example .env
#   2. 填入你自己申请的值
#   3. .env 会被 .gitignore 自动排除，不会进 commit
# ----------------------------------------------------------------------

# === GSC + GA4 数据源（搜索分析 MCP） ===
# 1. 进入 https://console.cloud.google.com/
# 2. 创建项目 → IAM → 服务账号 → 新建密钥（JSON）
# 3. 下载 JSON 到安全目录，路径填入下面
# 4. 去 GSC 把服务账号邮箱加到 "Users and permissions" → Full User
# 5. 去 GA4 Admin → Account/Property Access Management 加服务账号邮箱 → Viewer
GSC_CONFIG_PATH=/path/to/your/gsc-service-account.json
GA4_PROPERTY_ID=                      # 形如 123456789（GA4 Admin → Property details）

# === IndexNow（索引加速，免费） ===
# 1. 到 https://www.bing.com/indexnow 生成 key
# 2. 把 <key>.txt 放到客户站 public/ 目录
# 3. 这里填 key（用于 script 提交 URL）
INDEXNOW_KEY=

# === 企业微信推送（可选，自动巡检推送） ===
# 企微群聊 → 右键 → 添加群机器人 → 复制 webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# === 部署（可选，用于 deployer MCP） ===
# 你的客户站服务器 SSH 凭证。推荐用 SSH key，不要用密码。
# 如果必须用密码，这里填 base64 编码后的密码（防止肉眼偷窥）
DEPLOY_SSH_USER=
DEPLOY_SSH_HOST=
DEPLOY_SSH_PORT=22
DEPLOY_SSH_KEY_PATH=~/.ssh/id_ed25519

# === Web3Forms（可选，表单后端） ===
# 给客户站的 Contact 表单做后端
# 1. 到 https://web3forms.com 注册（邮箱验证即可）
# 2. 复制 access key 填到这里
WEB3FORMS_ACCESS_KEY=

# === Cloudflare（可选，用于 GEO 攻防 worker） ===
CF_API_TOKEN=
CF_ACCOUNT_ID=

# === Resend / 邮件发送（可选，用于 email MCP） ===
RESEND_API_KEY=

# === Anthropic（可选，当你需要让 AI Advisor 或额外模型调用时） ===
# 注意：Claude Code 本身不需要这个 key（它用你的 Claude 订阅）
# 仅当你部署了 AI 客服 worker 等时才需要
ANTHROPIC_API_KEY=

# === 运营数据持久化（pm2 cron 自动巡检时使用） ===
# 默认即可，除非你要改路径
REPORTS_DIR=./reports
