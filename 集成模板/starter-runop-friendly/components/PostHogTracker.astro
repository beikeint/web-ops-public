---
/**
 * PostHogTracker · A/B 测试 + Feature Flag SDK 注入器 (web-ops v10.1 batch 7)
 *
 * 配合 集成模板/ab-testing/INSTALL.md 使用 (PostHog Self-host 推荐).
 *
 * 使用方式 (site.config.ts):
 * features: { posthogAB: true },
 * posthog: {
 *   apiKey: 'phc_xxx',
 *   host: 'https://posthog.<your-domain>.com',  // self-host
 * }
 *
 * 集成步骤:
 * 1. 复制本文件到 src/components/interactive/PostHogTracker.astro
 * 2. BaseLayout.astro <head> 加: {config.features.posthogAB && <PostHogTracker />}
 * 3. site.config.ts 配 features.posthogAB + posthog.apiKey + posthog.host
 *
 * Feature Flag 使用:
 * ```astro
 * ---
 * // 服务端读取 flag
 * const variant = posthog.getFeatureFlag('hero-cta-test') || 'control';
 * const heroCta = variant === 'variant' ? 'Free Engineering Consult' : 'Get a Quote';
 * ---
 * <a onclick={`posthog.capture('hero_cta_click', {variant: '${variant}'})`}>
 *   {heroCta}
 * </a>
 * ```
 */
import config from '../../config/site.config';

const enabled = config.features?.posthogAB;
const apiKey = config.posthog?.apiKey;
const host = config.posthog?.host || 'https://app.posthog.com';
---

{enabled && apiKey && (
  <script is:inline define:vars={{ apiKey, host }}>
